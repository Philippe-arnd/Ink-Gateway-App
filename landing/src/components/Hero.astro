---
---

<section class="hero-wrapper">
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <div class="nav-logo">
        <img src="/logo.svg" alt="Ink-Gateway" width="20" height="24" />
        <span class="nav-brand">Ink-Gateway</span>
      </div>
      <div class="nav-links">
        <a href="#install">Install</a>
        <a href="#flow">How it works</a>
        <a href="#features">Features</a>
        <a href="https://github.com/Philippe-arnd/ink-gateway-app" class="nav-github" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
