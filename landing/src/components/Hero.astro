          </svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <div class="hero">
    <!-- Glow orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- Grid texture -->
    <div class="grid-texture"></div>

    <div class="hero-content">
      <!-- Badge -->
      <div class="badge">
        <span class="badge-dot"></span>
        <span>Alpha available — AI-powered fiction writing</span>
      </div>

      <!-- Headline -->
      <h1 class="headline">
        Your manuscript,<br/>
        <span class="headline-gradient">shaped by AI</span>
      </h1>

      <p class="hero-sub">
        A distraction-free prose editor paired with a Chat Agent that inserts prose,
        rewrites sections, and manages chapters — acting <em>directly</em> on your document.
      </p>

      <!-- Prose sample card -->
      <div class="prose-card">
        <div class="prose-card-label">
          <span class="prose-dot"></span>
          <span>Ink Agent writing · Chapter 3</span>
        </div>
        <blockquote class="prose-quote">
          The lighthouse keeper had not spoken to another soul in forty-seven days.
          She kept a tally on the wall beside the foghorn controls — not out of loneliness,
          but as a kind of scientific observation. <em>How long before silence becomes its own language?</em>
        </blockquote>
        <div class="prose-cursor"></div>
      </div>

      <!-- CTAs -->
      <div class="cta-row">
        <a href="#install" class="btn-primary">
          <img src="/logo.svg" alt="" width="14" height="19" style="filter: brightness(0) invert(1);" />
          Write with Ink
        </a>
        <a href="https://github.com/Philippe-arnd/ink-gateway-app" class="btn-ghost" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Meta bar -->
      <div class="meta-bar">
        <span class="meta-tag">Git as source of truth</span>
        <span class="meta-sep">·</span>
        <span class="meta-tag">MCP over SSE</span>
        <span class="meta-sep">·</span>
        <span class="meta-tag">Rust API</span>
        <span class="meta-sep">·</span>
        <span class="meta-tag">Open source</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-wrapper {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  /* ── Nav ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    background: rgba(248, 247, 244, 0.88);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-brand {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-links a {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-github {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    font-size: 13px !important;
    transition: border-color 0.2s, background 0.2s !important;
  }

  .nav-github:hover {
    background: rgba(0, 0, 0, 0.04) !important;
    border-color: rgba(0, 0, 0, 0.2) !important;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 120px 32px 80px;
  }

  /* Glow orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    animation: glowPulse 6s ease-in-out infinite;
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    top: -100px;
    left: -150px;
    background: radial-gradient(circle, rgba(79, 70, 229, 0.12) 0%, transparent 70%);
    animation-delay: 0s;
  }

  .orb-2 {
    width: 500px;
    height: 500px;
    top: 100px;
    right: -100px;
    background: radial-gradient(circle, rgba(192, 38, 211, 0.09) 0%, transparent 70%);
    animation-delay: -2s;
  }

  .orb-3 {
    width: 400px;
    height: 400px;
    bottom: -80px;
    left: 40%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.08) 0%, transparent 70%);
    animation-delay: -4s;
  }

  /* Grid texture */
  .grid-texture {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    pointer-events: none;
  }

  /* Hero content */
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 780px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 28px;
    animation: fadeUp 0.8s ease both;
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 100px;
    background: rgba(99, 102, 241, 0.08);
    font-size: 12px;
    font-family: var(--font-mono);
    font-weight: 300;
    color: rgba(99, 102, 241, 0.9);
    letter-spacing: 0.02em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--indigo);
    animation: dotPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* Headline */
  .headline {
    font-family: var(--font-serif);
    font-size: clamp(52px, 8vw, 96px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .headline-gradient {
    background: linear-gradient(135deg, var(--indigo) 0%, var(--violet) 40%, var(--fuchsia) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-style: italic;
    font-weight: 400;
  }

  /* Hero sub */
  .hero-sub {
    max-width: 560px;
    font-size: 17px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .hero-sub em {
    color: var(--text);
    font-style: italic;
    font-family: var(--font-serif);
  }

  /* Prose card */
  .prose-card {
    width: 100%;
    max-width: 600px;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    padding: 24px 28px;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  .prose-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--indigo), transparent);
    opacity: 0.4;
  }

  .prose-card-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    color: var(--indigo);
    margin-bottom: 16px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .prose-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--emerald);
    animation: dotPulse 1.5s ease-in-out infinite;
  }

  .prose-quote {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 300;
    font-style: italic;
    line-height: 1.75;
    color: rgba(17, 17, 17, 0.82);
    border: none;
  }

  .prose-quote em {
    font-style: normal;
    font-weight: 400;
  }

  .prose-cursor {
    display: inline-block;
    width: 2px;
    height: 18px;
    background: var(--indigo);
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  /* CTAs */
  .cta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: var(--radius);
    background: linear-gradient(135deg, var(--indigo) 0%, var(--fuchsia) 100%);
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.3);
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: var(--radius);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 400;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .btn-ghost:hover {
    border-color: rgba(0, 0, 0, 0.2);
    color: var(--text);
    background: rgba(0, 0, 0, 0.03);
  }

  /* Meta bar */
  .meta-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .meta-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  .meta-sep {
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-inner {
      padding: 0 20px;
    }

    .nav-links {
      gap: 16px;
    }

    .nav-links a:not(.nav-github) {
      display: none;
    }

    .hero {
      padding: 100px 20px 60px;
    }

    .hero-content {
      gap: 20px;
    }

    .headline {
      font-size: clamp(40px, 10vw, 64px);
    }

    .hero-sub {
      font-size: 15px;
      padding: 0 10px;
    }

    .prose-card {
      padding: 20px;
    }

    .prose-quote {
      font-size: 15px;
    }

    .cta-row {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .btn-primary, .btn-ghost {
      width: 100%;
      justify-content: center;
    }

    .meta-bar {
      gap: 8px;
      flex-direction: column;
      align-items: center;
    }

    .meta-tag {
      font-size: 10px;
    }
  }

  @media (max-width: 480px) {
    .nav-inner {
      justify-content: center;
      gap: 20px;
    }

    .nav-brand {
      display: none;
    }
    
    .nav-links a:not(.nav-github) {
      display: none;
    }
    
    .meta-sep {
      display: none;
    }
  }
</style>
