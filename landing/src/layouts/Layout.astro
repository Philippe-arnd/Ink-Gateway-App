---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ink-Gateway — Write with an AI that acts on your manuscript',
  description = 'A distraction-free prose editor paired with an AI Chat Agent that inserts prose, rewrites sections, and manages chapters — directly in your document, committed to Git.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,500;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Mono:wght@300;400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #f8f7f4;
    --surface: #ffffff;
    --surface-2: #eef0ff;
    --border: rgba(0, 0, 0, 0.08);
    --border-strong: rgba(0, 0, 0, 0.15);
    --indigo: #4f46e5;
    --fuchsia: #c026d3;
    --violet: #7c3aed;
    --text: #111111;
    --text-muted: #6b6b6b;
    --text-dim: #9b9b9b;
    --emerald: #059669;
    --font-sans: 'DM Sans', system-ui, sans-serif;
    --font-serif: 'Cormorant Garant', Georgia, serif;
    --font-mono: 'DM Mono', 'Fira Mono', monospace;
    --radius: 8px;
    --radius-lg: 16px;
    --radius-xl: 24px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #aaa;
  }

  ::selection {
    background: rgba(79, 70, 229, 0.15);
    color: var(--text);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.08); }
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  @keyframes dashFlow {
    from { stroke-dashoffset: 20; }
    to { stroke-dashoffset: 0; }
  }

  @keyframes dotTravel {
    0% { left: 0%; opacity: 0; }
    5% { opacity: 1; }
    95% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  @keyframes dotTravelReverse {
    0% { left: 100%; opacity: 0; }
    5% { opacity: 1; }
    95% { opacity: 1; }
    100% { left: 0%; opacity: 0; }
  }

  @keyframes pulseBorder {
    0%, 100% { border-color: rgba(99, 102, 241, 0.4); box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
    50% { border-color: rgba(99, 102, 241, 0.8); box-shadow: 0 0 20px 4px rgba(99, 102, 241, 0.15); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes shimmer {
    from { background-position: -200% center; }
    to { background-position: 200% center; }
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }
</style>
